<!-- Parser-friendly hub screen modeled after the official LVGL Editor examples. -->
<screen>
	<styles>
		<style
			name="card"
			bg_color="0x243532"
			bg_opa="100%"
			border_width="2"
			border_color="0x34593c"
			radius="28"
			pad_all="18"
			pad_row="12"
			pad_column="12"
		/>
		<style
			name="halo"
			bg_color="0x23402e"
			bg_opa="100%"
			border_width="1"
			border_color="0x2c5037"
			radius="22"
			pad_all="0"
		/>
		<style
			name="chip"
			bg_color="0x34593c"
			bg_opa="100%"
			border_width="0"
			radius="14"
			pad_left="14"
			pad_right="14"
			pad_top="6"
			pad_bottom="6"
		/>
		<style name="chip_text" text_color="0x69ea79" />
		<style name="title" text_color="0x69ea79" />
		<style name="subtitle" text_color="0xf3f7fa" />
		<style name="footer" text_color="0x468f53" />
		<style
			name="dot_idle"
			bg_color="0x34593c"
			bg_opa="100%"
			border_width="0"
			radius="3"
		/>
		<style
			name="dot_active"
			bg_color="0x69ea79"
			bg_opa="100%"
			border_width="0"
			radius="4"
		/>
		<style
			name="battery_frame"
			bg_opa="0%"
			border_width="1"
			border_color="0x99a0ad"
			radius="2"
			pad_all="0"
		/>
	</styles>

	<view
		flex_flow="column"
		style_bg_color="0x12151c"
		style_bg_opa="100%"
		style_border_width="0"
		style_pad_all="16"
		style_pad_row="12"
	>
		<lv_obj
			width="100%"
			height="20"
			flex_flow="row"
			style_bg_opa="0%"
			style_border_width="0"
			style_pad_all="0"
			style_flex_main_place="space_between"
			style_flex_cross_place="center"
		>
			<lv_obj
				width="content"
				height="content"
				flex_flow="row"
				style_bg_opa="0%"
				style_border_width="0"
				style_pad_all="0"
				style_pad_column="8"
				style_flex_cross_place="center"
			>
				<lv_obj width="8" height="8" style_bg_color="0x3ddd53" style_bg_opa="100%" style_radius="4" style_border_width="0" />
				<lv_label text="09:41" style_text_color="0xf3f7fa" />
			</lv_obj>

			<lv_obj
				width="content"
				height="content"
				flex_flow="row"
				style_bg_opa="0%"
				style_border_width="0"
				style_pad_all="0"
				style_pad_column="2"
				style_flex_cross_place="center"
			>
				<lv_obj width="20" height="10">
					<style name="battery_frame" />
				</lv_obj>
				<lv_obj width="2" height="4" style_bg_color="0x99a0ad" style_bg_opa="100%" style_border_width="0" style_radius="1" />
			</lv_obj>
		</lv_obj>

		<lv_obj
			width="100%"
			flex_grow="1"
			flex_flow="column"
			style_flex_main_place="space_between"
			style_flex_cross_place="center"
		>
			<style name="card" />

			<lv_obj
				width="144"
				height="96"
				flex_flow="column"
				style_flex_main_place="center"
				style_flex_cross_place="center"
			>
				<style name="halo" />

				<lv_obj width="content" height="content">
					<style name="chip" />
					<lv_label text="LISTEN">
						<style name="chip_text" />
					</lv_label>
				</lv_obj>
			</lv_obj>

			<lv_obj
				width="100%"
				height="content"
				flex_flow="column"
				style_bg_opa="0%"
				style_border_width="0"
				style_pad_all="0"
				style_pad_row="8"
				style_flex_cross_place="center"
			>
				<lv_label text="Listen">
					<style name="title" />
				</lv_label>
				<lv_label text="On-device music">
					<style name="subtitle" />
				</lv_label>
			</lv_obj>

			<lv_obj
				width="content"
				height="content"
				flex_flow="row"
				style_bg_opa="0%"
				style_border_width="0"
				style_pad_all="0"
				style_pad_column="10"
				style_flex_cross_place="center"
			>
				<lv_obj width="6" height="6">
					<style name="dot_idle" />
				</lv_obj>
				<lv_obj width="8" height="8">
					<style name="dot_active" />
				</lv_obj>
				<lv_obj width="6" height="6">
					<style name="dot_idle" />
				</lv_obj>
				<lv_obj width="6" height="6">
					<style name="dot_idle" />
				</lv_obj>
			</lv_obj>
		</lv_obj>

		<lv_label text="Tap next / Double open">
			<style name="footer" />
		</lv_label>
	</view>
</screen>
