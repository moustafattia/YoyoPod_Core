<!-- Parser-friendly main menu screen modeled after the official LVGL Editor examples. -->
<screen>
	<styles>
		<style
			name="menu_mode_chip"
			bg_color="0x34593c"
			bg_opa="100%"
			border_width="0"
			radius="12"
			pad_left="12"
			pad_right="12"
			pad_top="5"
			pad_bottom="5"
		/>
		<style name="menu_mode_chip_text" text_color="0x69ea79" />
		<style name="menu_title" text_color="0xf3f7fa" />
		<style name="menu_subtitle" text_color="0x99a0ad" />
		<style
			name="menu_rule"
			bg_color="0x69ea79"
			bg_opa="100%"
			border_width="0"
			radius="2"
		/>
		<style
			name="menu_shell"
			bg_color="0x1e2229"
			bg_opa="100%"
			border_width="0"
			radius="24"
			pad_all="12"
			pad_row="8"
		/>
		<style
			name="menu_row_selected"
			bg_color="0x243532"
			bg_opa="100%"
			border_width="1"
			border_color="0x468f53"
			radius="16"
			pad_left="10"
			pad_right="10"
			pad_top="8"
			pad_bottom="8"
		/>
		<style
			name="menu_row_idle"
			bg_color="0x1c212a"
			bg_opa="100%"
			border_width="1"
			border_color="0x4a4f5c"
			radius="16"
			pad_left="10"
			pad_right="10"
			pad_top="8"
			pad_bottom="8"
		/>
		<style
			name="menu_dot_selected"
			bg_color="0x69ea79"
			bg_opa="100%"
			border_width="0"
			radius="3"
		/>
		<style
			name="menu_dot_idle"
			bg_color="0x4a4f5c"
			bg_opa="100%"
			border_width="0"
			radius="3"
		/>
		<style name="menu_row_title" text_color="0xf3f7fa" />
		<style name="menu_row_detail_selected" text_color="0x69ea79" />
		<style name="menu_row_detail_idle" text_color="0x99a0ad" />
		<style
			name="menu_badge_listen"
			bg_color="0x34593c"
			bg_opa="100%"
			border_width="0"
			radius="12"
			pad_left="10"
			pad_right="10"
			pad_top="5"
			pad_bottom="5"
		/>
		<style
			name="menu_badge_talk"
			bg_color="0x2e5764"
			bg_opa="100%"
			border_width="0"
			radius="12"
			pad_left="10"
			pad_right="10"
			pad_top="5"
			pad_bottom="5"
		/>
		<style
			name="menu_badge_ask"
			bg_color="0x705c21"
			bg_opa="100%"
			border_width="0"
			radius="12"
			pad_left="10"
			pad_right="10"
			pad_top="5"
			pad_bottom="5"
		/>
		<style
			name="menu_badge_setup"
			bg_color="0x4d545c"
			bg_opa="100%"
			border_width="0"
			radius="12"
			pad_left="10"
			pad_right="10"
			pad_top="5"
			pad_bottom="5"
		/>
		<style name="menu_badge_listen_text" text_color="0x69ea79" />
		<style name="menu_badge_talk_text" text_color="0x52dcff" />
		<style name="menu_badge_ask_text" text_color="0xffd549" />
		<style name="menu_badge_setup_text" text_color="0xb7bec8" />
		<style name="menu_footer" text_color="0x468f53" />
	</styles>

	<view
		flex_flow="column"
		style_bg_color="0x12151c"
		style_bg_opa="100%"
		style_border_width="0"
		style_pad_all="16"
		style_pad_row="10"
	>
		<lv_obj
			width="100%"
			height="20"
			flex_flow="row"
			style_bg_opa="0%"
			style_border_width="0"
			style_pad_all="0"
			style_pad_column="8"
			style_flex_cross_place="center"
		>
			<lv_obj width="8" height="8" style_bg_color="0x3ddd53" style_bg_opa="100%" style_radius="4" style_border_width="0" />
			<lv_label text="YoyoPod" style_text_color="0xf3f7fa" />
		</lv_obj>

		<lv_obj
			width="100%"
			height="content"
			flex_flow="column"
			style_bg_opa="0%"
			style_border_width="0"
			style_pad_all="0"
			style_pad_row="8"
		>
			<lv_obj width="content" height="content">
				<style name="menu_mode_chip" />
				<lv_label text="LISTEN">
					<style name="menu_mode_chip_text" />
				</lv_label>
			</lv_obj>

			<lv_label text="YoyoPod">
				<style name="menu_title" />
			</lv_label>

			<lv_obj width="94" height="3">
				<style name="menu_rule" />
			</lv_obj>

			<lv_label text="Pick a mode for this adventure.">
				<style name="menu_subtitle" />
			</lv_label>
		</lv_obj>

		<lv_obj
			width="100%"
			flex_grow="1"
			flex_flow="column"
		>
			<style name="menu_shell" />

			<lv_obj
				width="100%"
				height="content"
				flex_flow="row"
				style_flex_main_place="space_between"
				style_flex_cross_place="center"
			>
				<style name="menu_row_selected" />

				<lv_obj
					width="content"
					height="content"
					flex_flow="row"
					style_bg_opa="0%"
					style_border_width="0"
					style_pad_all="0"
					style_pad_column="10"
					style_flex_cross_place="center"
				>
					<lv_obj width="6" height="6">
						<style name="menu_dot_selected" />
					</lv_obj>
					<lv_label text="Listen">
						<style name="menu_row_title" />
					</lv_label>
					<lv_label text="- Music and playlists">
						<style name="menu_row_detail_selected" />
					</lv_label>
				</lv_obj>

				<lv_obj width="content" height="content">
					<style name="menu_badge_listen" />
					<lv_label text="OPEN">
						<style name="menu_badge_listen_text" />
					</lv_label>
				</lv_obj>
			</lv_obj>

			<lv_obj
				width="100%"
				height="content"
				flex_flow="row"
				style_flex_main_place="space_between"
				style_flex_cross_place="center"
			>
				<style name="menu_row_idle" />

				<lv_obj
					width="content"
					height="content"
					flex_flow="row"
					style_bg_opa="0%"
					style_border_width="0"
					style_pad_all="0"
					style_pad_column="10"
					style_flex_cross_place="center"
				>
					<lv_obj width="6" height="6">
						<style name="menu_dot_idle" />
					</lv_obj>
					<lv_label text="Talk">
						<style name="menu_row_title" />
					</lv_label>
					<lv_label text="- Calls and voice notes">
						<style name="menu_row_detail_idle" />
					</lv_label>
				</lv_obj>

				<lv_obj width="content" height="content">
					<style name="menu_badge_talk" />
					<lv_label text="TALK">
						<style name="menu_badge_talk_text" />
					</lv_label>
				</lv_obj>
			</lv_obj>

			<lv_obj
				width="100%"
				height="content"
				flex_flow="row"
				style_flex_main_place="space_between"
				style_flex_cross_place="center"
			>
				<style name="menu_row_idle" />

				<lv_obj
					width="content"
					height="content"
					flex_flow="row"
					style_bg_opa="0%"
					style_border_width="0"
					style_pad_all="0"
					style_pad_column="10"
					style_flex_cross_place="center"
				>
					<lv_obj width="6" height="6">
						<style name="menu_dot_idle" />
					</lv_obj>
					<lv_label text="Ask">
						<style name="menu_row_title" />
					</lv_label>
					<lv_label text="- Safe questions">
						<style name="menu_row_detail_idle" />
					</lv_label>
				</lv_obj>

				<lv_obj width="content" height="content">
					<style name="menu_badge_ask" />
					<lv_label text="ASK">
						<style name="menu_badge_ask_text" />
					</lv_label>
				</lv_obj>
			</lv_obj>

			<lv_obj
				width="100%"
				height="content"
				flex_flow="row"
				style_flex_main_place="space_between"
				style_flex_cross_place="center"
			>
				<style name="menu_row_idle" />

				<lv_obj
					width="content"
					height="content"
					flex_flow="row"
					style_bg_opa="0%"
					style_border_width="0"
					style_pad_all="0"
					style_pad_column="10"
					style_flex_cross_place="center"
				>
					<lv_obj width="6" height="6">
						<style name="menu_dot_idle" />
					</lv_obj>
					<lv_label text="Setup">
						<style name="menu_row_title" />
					</lv_label>
					<lv_label text="- Power and device care">
						<style name="menu_row_detail_idle" />
					</lv_label>
				</lv_obj>

				<lv_obj width="content" height="content">
					<style name="menu_badge_setup" />
					<lv_label text="SETUP">
						<style name="menu_badge_setup_text" />
					</lv_label>
				</lv_obj>
			</lv_obj>
		</lv_obj>

		<lv_label text="A open | B back | X/Y move">
			<style name="menu_footer" />
		</lv_label>
	</view>
</screen>
